    "devDependencies": {
        "@nestjs/cli": "catalog:api",
        "@nestjs/schematics": "catalog:api",
        "@nestjs/testing": "catalog:api",
        "@types/body-parser": "^1.19.6",
        "@types/express": "catalog:api",
        "@types/multer": "^1.4.13",
        "@types/node": "catalog:dev",
        "@types/semver": "^7.7.1",
        "body-parser": "2.2.0",
        "clsx": "catalog:web",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "eslint": "catalog:dev",
        "eslint-plugin-format": "catalog:dev",
        "eslint-plugin-vue": "catalog:dev",
