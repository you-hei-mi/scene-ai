{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "BuildingAI",
    "version": "26.0.0",
    "identifier": "cc.buildingai.client",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:4091",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "BuildingAI",
                "width": 1152,
                "height": 720,
                "minWidth": 1152,
                "minHeight": 720
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
