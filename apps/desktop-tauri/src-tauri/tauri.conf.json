{
  "$schema": "https://schema.tauri.app/config/1.5",
  "productName": "BuildingAI",
  "version": "1.0.0",
  "identifier": "com.buildingai.desktop",
  "description": "BuildingAI Desktop Application",
  "copyright": "2024 BuildingAI",
  "icon": "icons/icon.png",

  "build": {
    "beforeBuildCommand": "cd ../web-nuxt && pnpm build",
    "beforeDevCommand": "cd ../web-nuxt && pnpm dev",
    "devUrl": "http://localhost:3000",
    "distDir": "../web-nuxt/.output/public"
  },

  "package": {
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "en-US",
        "template": null,
        "productLanguage": 1033
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "entitlements": null,
      "entitlementsInherit": null,
      "exceptionDomain": "",
      "signingIdentity": null,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false
    },
    "linux": {
      "targetDeb": "debian",
      "targetAppImage": true,
      "targetRpm": false,
      "icon": ["icons/icon_128x128.png", "icons/icon_256x256.png", "icons/icon_512x512.png"]
    }
  },

  "tauri": {
    "allowlist": {
      "all": true,
      "fs": {
        "all": true,
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "createDir": true,
        "removeDir": true,
        "removeFile": true,
        "renameFile": true,
        "copyFile": true
      },
      "dialog": {
        "all": true,
        "open": true,
        "save": true,
        "message": true
      },
      "window": {
        "all": true
      },
      "shell": {
        "all": false,
        "open": true
      },
      "updater": {
        "all": true
      }
    },

    "windows": [
      {
        "title": "BuildingAI",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "url": "/",
        "center": true
      }
    ],

    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menu": [
        {
          "label": "打开主窗口",
          "action": "show"
        },
        {
          "label": "最小化",
          "action": "hide"
        },
        {
          "type": "separator"
        },
        {
          "label": "检查更新",
          "action": "check-update"
        },
        {
          "type": "separator"
        },
        {
          "label": "退出",
          "action": "quit"
        }
      ]
    },

    "updater": {
      "active": true,
      "endpoints": [
        "https://releases.buildingai.com/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRFQjQ5Q0Y2QUQ3NzJDMUIKZXhwaXJlOiAyMDI0LTAxLTAxVDAwOjAwOjAwWgo="
    },

    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' http://localhost:4090 https://api.buildingai.com;",
      "capabilities": []
    }
  }
}
