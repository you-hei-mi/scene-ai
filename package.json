        "rimraf": "^6.1.3",
        "sass": "catalog:web",
        "semver": "^7.7.4",
        "sonner": "^2.0.7",
        "tailwind-merge": "catalog:web",
        "tailwindcss": "catalog:web",
        "tailwindcss-animate": "catalog:web",
        "tiptap-markdown": "catalog:web",
        "typeorm": "0.3.27",
        "typeorm-naming-strategies": "catalog:api",
        "uuid": "^13.0.0",
        "vite": "8.0.0",
        "vue": "catalog:web",
        "vue-dompurify-html": "catalog:web",
        "vue-renderer-markdown": "catalog:web",
        "vue-router": "catalog:web",
        "vuedraggable": "catalog:web",
